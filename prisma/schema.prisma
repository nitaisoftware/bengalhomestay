generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  guest
  host
  admin
}

enum OwnerTier {
  free
  paid
}

enum CategoryGroup {
  wildlife
  heritage
  spiritual
  adventure
  rural
  nature
}

enum HomestayStatus {
  draft
  pending_review
  approved
  rejected
  suspended
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  mobile                String?   @unique
  email                 String?   @unique
  name                  String?
  avatarUrl             String?
  gender                String?
  dob                   DateTime?
  address               String?
  city                  String?
  district              String?
  state                 String?
  pincode               String?
  role                  UserRole  @default(guest)
  tier                  OwnerTier @default(free)
  onboardingComplete    Boolean   @default(false)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  homestays Homestay[]
  reviews   Review[]
  bookings  Booking[]

  @@map("users")
}

// ─── Categories / Tags ───────────────────────────────────────────────────────

model Category {
  id    String        @id @default(uuid())
  group CategoryGroup
  name  String
  slug  String        @unique
  icon  String?

  homestayCategories HomestayCategory[]

  @@map("categories")
}

// ─── Homestays ───────────────────────────────────────────────────────────────

model Homestay {
  id          String         @id @default(uuid())
  slug        String         @unique
  name        String
  description String?
  status      HomestayStatus @default(draft)

  // Location
  address  String?
  district String
  state    String  @default("West Bengal")
  pincode  String?
  lat      Float?
  lng      Float?

  // Pricing
  pricePerNight Float
  minStayDays   Int   @default(1)
  maxStayDays   Int   @default(30)

  // Amenities
  amenities String[]

  // Contact (hidden from public; visible only for premium listings)
  phone        String?
  contactEmail String?

  // Premium
  isFeatured Boolean @default(false)
  isPremium  Boolean @default(false)

  // Owner
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooms      Room[]
  images     HomestayImage[]
  categories HomestayCategory[]
  reviews    Review[]
  bookings   Booking[]

  @@index([district])
  @@index([status])
  @@index([pricePerNight])
  @@map("homestays")
}

// ─── Rooms ───────────────────────────────────────────────────────────────────

model Room {
  id            String   @id @default(uuid())
  homestayId    String
  homestay      Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  capacity      Int
  bedType       String?
  pricePerNight Float
  amenities     String[]
  createdAt     DateTime @default(now())

  @@map("rooms")
}

// ─── Images ──────────────────────────────────────────────────────────────────

model HomestayImage {
  id         String   @id @default(uuid())
  homestayId String
  homestay   Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  url        String
  publicId   String?
  altText    String?
  isCover    Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("homestay_images")
}

// ─── Homestay <-> Category (many-to-many) ────────────────────────────────────

model HomestayCategory {
  homestayId String
  categoryId String
  homestay   Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([homestayId, categoryId])
  @@map("homestay_categories")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid())
  homestayId String
  homestay   Homestay @relation(fields: [homestayId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@map("reviews")
}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  id                String        @id @default(uuid())
  homestayId        String
  homestay          Homestay      @relation(fields: [homestayId], references: [id])
  guestId           String
  guest             User          @relation(fields: [guestId], references: [id])
  checkIn           DateTime
  checkOut          DateTime
  guests            Int
  roomsRequested    Int           @default(1)
  totalAmount       Float
  status            BookingStatus @default(pending)
  message           String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("bookings")
}
