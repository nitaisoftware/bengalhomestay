# ── Database
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/bengalhomestay?sslmode=require

# ── Redis (Upstash)
REDIS_URL=rediss://default:token@xxx.upstash.io:6379

# ── JWT
JWT_SECRET=replace-with-256-bit-secret
REFRESH_SECRET=replace-with-refresh-secret

# ── MSG91 OTP
MSG91_API_KEY=your-msg91-key
MSG91_TEMPLATE_ID=your-dlt-template-id
MSG91_SENDER_ID=BNGHST

# ── Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Google
GOOGLE_MAPS_API_KEY=your-maps-key
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-secret

# ── Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── App
NEXT_PUBLIC_SITE_URL=https://bengalhomestay.com
API_URL=https://api.bengalhomestay.com
SCRAPER_BOT_USER_ID=replace-with-seeded-bot-user-uuid
NODE_ENV=development
